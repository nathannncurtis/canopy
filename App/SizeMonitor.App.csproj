<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>SizeMonitor</RootNamespace>
    <AssemblyName>Canopy</AssemblyName>
    <Version>1.0.0</Version>
    <Authors>Nathan Curtis</Authors>
    <Product>Canopy</Product>
    <AssemblyTitle>Canopy</AssemblyTitle>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WPF-UI" Version="4.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Interop\SizeMonitor.Interop.csproj" />
  </ItemGroup>
</Project>
