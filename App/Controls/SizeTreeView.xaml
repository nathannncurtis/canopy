<UserControl x:Class="SizeMonitor.Controls.SizeTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:SizeMonitor.Controls">
    <UserControl.Resources>
        <HierarchicalDataTemplate x:Key="NodeTemplate"
                                  DataType="{x:Type local:SizeNodeView}"
                                  ItemsSource="{Binding Children}">
            <Grid Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           Padding="2,0" />

                <ProgressBar Grid.Column="1" Height="8" VerticalAlignment="Center"
                             Margin="4,0"
                             Minimum="0" Maximum="1"
                             Value="{Binding SizeBarFraction}"
                             Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                             Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <TextBlock Grid.Column="2" Text="{Binding SizeText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Opacity="0.7" FontSize="11" />
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <TreeView x:Name="_tree"
              ItemTemplate="{StaticResource NodeTemplate}"
              Background="Transparent" BorderThickness="0"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              SelectedItemChanged="OnSelectedItemChanged" />
</UserControl>
